# Node.js dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build and distribution
dist/
build/

# Test outputs
coverage/

# Plug'n'Play
.pnp
.pnp.js

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS and editor-specific
.DS_Store
Thumbs.db
