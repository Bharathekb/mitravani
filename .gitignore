package-lock.json
yarn.lock
pnpm-lock.yaml

# Exclude generated bundles or binaries
*.bundle.js
*.min.js
*.map

# Ignore compiled output
*.out
*.pyc
*.class

# Ignore frontend build tools outputs
/.parcel-cache/
*.eslintcache
*.stylelintcache
